{
  "expo": {
    "name": "DotFuel",
    "slug": "app-dotfuel-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "appdotfuelshop",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.dotcreations.dotfuel",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DotFuel needs camera access to scan food barcodes and take meal photos."
      }
    },
    "android": {
      "package": "com.dotcreations.dotfuel",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "display": "standalone",
      "themeColor": "#0A0A0A",
      "backgroundColor": "#0A0A0A"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "DotFuel needs camera access to scan food barcodes and take meal photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3997fd8a-ed84-423d-b1e1-d71ca6a60ad8"
      }
    },
    "owner": "dotcreations"
  }
}
